include ./conf.d/binds.conf
include ./conf.d/rules.conf
include ./conf.d/startup.conf
include ./themes/default.conf

output HDMI-A-1 resolution 1920x1080@74.973Hz position 0 0

input "type:keyboard" {
    xkb_layout us,es
    xkb_variant ,
    xkb_options grp:alt_shift_toggle,caps:escape
}

default_border normal 1
titlebar_border_thickness 1
titlebar_padding 4 1
client.focused   #000000 #B4EEB4 #000000 #B4EEB4 #868686
